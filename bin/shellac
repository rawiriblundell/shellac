# Ensure that this file is sourced, not executed, and bail out if already loaded
# See: https://stackoverflow.com/a/28776166
[ -n "${SHELLAC_LOADED+x}" ] && return 0
SHELLAC_LOADED=0
if [ -n "${ZSH_VERSION}" ]; then
  case "${ZSH_EVAL_CONTEXT}" in (*:file) SHELLAC_LOADED=1 ;; esac
elif [ -n "${KSH_VERSION}" ]; then
  # shellcheck disable=SC2296  # ${.sh.file} is KSH93-specific syntax; not valid in bash
  [ "$(cd -- "$(dirname -- "$0")" && pwd -P)/$(basename -- "$0")" != "$(cd -- "$(dirname -- "${.sh.file}")" && pwd -P)/$(basename -- "${.sh.file}")" ] && SHELLAC_LOADED=1
elif [ -n "${BASH_VERSION}" ]; then
  (return 0 2>/dev/null) && SHELLAC_LOADED=1
else
  case "${0##*/}" in (sh|-sh|dash|-dash) SHELLAC_LOADED=1 ;; esac
fi

if [ "${SHELLAC_LOADED}" -eq 0 ]; then
  printf -- '%s\n' "Error: shellac must be sourced, not executed" >&2
  exit 1
fi

# Record init time for relative timestamps in the stack trace
SHELLAC_INIT_TIME="${SECONDS}"

# Start up SH_STACK
# bashism: arrays require bash/ksh/zsh; not available in POSIX sh
SH_STACK=()
sh_stack_add() {
  local _elapsed
  local _depth
  local _arrow
  local _i

  _elapsed=$(( SECONDS - SHELLAC_INIT_TIME ))

  # bashism: FUNCNAME array is bash/zsh-specific
  # depth = number of call frames above sh_stack_add itself
  _depth=$(( ${#FUNCNAME[@]} - 1 ))
  (( _depth < 0 )) && _depth=0
  (( _depth > 8 )) && _depth=8

  _arrow='=>'
  _i=0
  # bashism: (( )) arithmetic compound command; not POSIX sh
  while (( _i < _depth )); do
    _arrow="${_arrow}>"
    (( _i += 1 ))
  done

  SH_STACK+=( "$(printf -- '+%04d: %s %s' "${_elapsed}" "${_arrow}" "${*}")" )
}
sh_stack_add "START"

# XDG config paths — defined here so add-libpath and the discovery block share them
SHELLAC_CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/shellac"
SHELLAC_PATHS_CONF="${SHELLAC_CONFIG_DIR}/paths.conf"
SHELLAC_CONFPATHS_CONF="${SHELLAC_CONFIG_DIR}/confpaths.conf"

# If SH_LIBPATH is already defined in the environment, use it directly.
# This allows a site admin to pre-configure SH_LIBPATH via e.g.
# /etc/profile.d/00-shellac.sh, which can also add /opt/shellac/bin to PATH.
if [ -n "${SH_LIBPATH}" ]; then
  sh_stack_add "SH_LIBPATH: already set in environment, skipping discovery"
  # bashism: 'read -ra' and herestring require bash; acceptable as this file requires bash
  IFS=':' read -ra SH_LIBPATH_ARRAY <<< "${SH_LIBPATH}"
else
  # Derive candidate from this file's own location (bin/shellac → lib/sh).
  # Handles dev clones, custom prefixes, and direct profile.d sourcing without
  # any configuration.  Falls through gracefully if the path doesn't resolve.
  _self_libpath="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
  _self_libpath="${_self_libpath%/bin}/lib/sh"

  # Potential basepaths for where our libraries might be placed
  POSSIBLE_SH_LIBPATHS=(
    "${_self_libpath}"
    "${XDG_DATA_HOME:-${HOME}/.local/share}/shellac/lib/sh"
    "${HOME}/.local/lib/sh"
    /opt/shellac/lib/sh
    /usr/local/lib/sh
  )
  unset -v _self_libpath

  # Append shellac/lib/sh under each dir in XDG_DATA_DIRS
  # bashism: 'read -ra' and herestring for splitting colon-separated var
  IFS=':' read -ra _xdg_dirs <<< "${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
  for _xdg_dir in "${_xdg_dirs[@]}"; do
    POSSIBLE_SH_LIBPATHS+=( "${_xdg_dir}/shellac/lib/sh" )
  done
  unset -v _xdg_dirs _xdg_dir

  # Append any paths from the user's paths.conf
  if [ -r "${SHELLAC_PATHS_CONF}" ]; then
    while IFS= read -r _conf_path; do
      case "${_conf_path}" in
        ('#'*|'') continue ;;
      esac
      POSSIBLE_SH_LIBPATHS+=( "${_conf_path}" )
    done < "${SHELLAC_PATHS_CONF}"
    unset -v _conf_path
  fi

  # we dynamically build SH_LIBPATH as a var and an array
  unset -v SH_LIBPATH SH_LIBPATH_ARRAY
  for _path in "${POSSIBLE_SH_LIBPATHS[@]}"; do
    if [ -d "${_path}" ]; then
      sh_stack_add "SH_LIBPATH: checking if ${_path} exists... found!"
      SH_LIBPATH="${SH_LIBPATH}:${_path}"
      SH_LIBPATH_ARRAY+=( "${_path}" )
    else
      sh_stack_add "SH_LIBPATH: checking if ${_path} exists... not found."
    fi
  done
  unset -v _path
  # Remove any leading colons from the construction process and export
  SH_LIBPATH="${SH_LIBPATH#:}"

  # If FPATH or fpath are present in the environment, append them
  if (( ${#FPATH} > 0 )); then
    SH_LIBPATH="${SH_LIBPATH}:${FPATH}"
  fi

  # shellcheck disable=SC2154  # fpath is a zsh array variable; may be set in environment
  if (( ${#fpath} > 0 )); then
    SH_LIBPATH="${SH_LIBPATH}:${fpath}"
  fi

  # Now, de-duplicate
  SH_LIBPATH=$(printf -- '%s\n' "${SH_LIBPATH}" | tr ':' '\n' | awk '!s[$0]++' | paste -sd ':' -)

  # Rebuild the array from the deduplicated string so the two stay in sync
  IFS=':' read -ra SH_LIBPATH_ARRAY <<< "${SH_LIBPATH}"

  # Finally, export
  export SH_LIBPATH
fi

# Check the length of the var again and fail out if it's empty
if (( "${#SH_LIBPATH}" == 0 )); then
  printf -- '%s\n' "SH_LIBPATH appears to be empty" >&2
  exit 1
fi

sh_stack_add "SH_LIBPATH: ${SH_LIBPATH}"

# If SH_CONFPATH is already defined in the environment, use it directly.
# Config paths are ordered system→user so later sources override earlier ones.
if [ -n "${SH_CONFPATH}" ]; then
  sh_stack_add "SH_CONFPATH: already set in environment, skipping discovery"
  # bashism: 'read -ra' and herestring for splitting colon-separated var
  IFS=':' read -ra SH_CONFPATH_ARRAY <<< "${SH_CONFPATH}"
else
  # Config search paths, ordered system→user (ascending precedence).
  # Unlike SH_LIBPATH, these are plain directories — no shellac-specific subdirs.
  POSSIBLE_SH_CONFPATHS=(
    /etc
    /opt/shellac/etc
  )

  # Append each dir in XDG_CONFIG_DIRS (default /etc/xdg)
  # bashism: 'read -ra' and herestring for splitting colon-separated var
  IFS=':' read -ra _xdg_config_dirs <<< "${XDG_CONFIG_DIRS:-/etc/xdg}"
  for _xdg_config_dir in "${_xdg_config_dirs[@]}"; do
    POSSIBLE_SH_CONFPATHS+=( "${_xdg_config_dir}" )
  done
  unset -v _xdg_config_dirs _xdg_config_dir

  # User XDG config dir last — highest precedence
  POSSIBLE_SH_CONFPATHS+=( "${XDG_CONFIG_HOME:-${HOME}/.config}" )

  # Append any paths from the user's confpaths.conf
  if [ -r "${SHELLAC_CONFPATHS_CONF}" ]; then
    while IFS= read -r _conf_path; do
      case "${_conf_path}" in
        ('#'*|'') continue ;;
      esac
      POSSIBLE_SH_CONFPATHS+=( "${_conf_path}" )
    done < "${SHELLAC_CONFPATHS_CONF}"
    unset -v _conf_path
  fi

  unset -v SH_CONFPATH SH_CONFPATH_ARRAY
  for _path in "${POSSIBLE_SH_CONFPATHS[@]}"; do
    if [ -d "${_path}" ]; then
      sh_stack_add "SH_CONFPATH: checking if ${_path} exists... found!"
      SH_CONFPATH="${SH_CONFPATH}:${_path}"
      SH_CONFPATH_ARRAY+=( "${_path}" )
    else
      sh_stack_add "SH_CONFPATH: checking if ${_path} exists... not found."
    fi
  done
  unset -v _path
  SH_CONFPATH="${SH_CONFPATH#:}"

  # De-duplicate
  SH_CONFPATH=$(printf -- '%s\n' "${SH_CONFPATH}" | tr ':' '\n' | awk '!s[$0]++' | paste -sd ':' -)

  export SH_CONFPATH
fi

# An empty SH_CONFPATH is non-fatal; wants() still works with full paths
sh_stack_add "SH_CONFPATH: ${SH_CONFPATH}"

# Bootstrap core functions from the first SH_LIBPATH element that has them
for _element in "${SH_LIBPATH_ARRAY[@]}"; do
  if [ -r "${_element}/core/include.sh" ]; then
    # shellcheck disable=SC1090
    . "${_element}/core/include.sh"
    # shellcheck disable=SC1090
    . "${_element}/core/requires.sh"
    # shellcheck disable=SC1090
    . "${_element}/core/wants.sh"
    break
  fi
done
unset -v _element

# @internal
# Print or clear the shellac trace stack.
_shellac_stack() {
  local _subcmd
  _subcmd="${1:-dump}"
  shift 2>/dev/null

  case "${_subcmd}" in
    (dump)
      printf -- '%s\n' "${SH_STACK[@]}"
    ;;
    (clear)
      SH_STACK=()
    ;;
    (*)
      printf -- 'shellac stack: unknown subcommand: %s\n' "${_subcmd}" >&2
      return 1
    ;;
  esac
}

# @internal
_is_function_loaded() {
  # bashism: typeset -f is bash/ksh/zsh; not POSIX sh (declare -f is bash-only)
  typeset -f "${1:?No function defined}" >/dev/null
}

# @internal
# Print a sorted list of unique module (subdirectory) names across SH_LIBPATH.
_shellac_ls_modules() {
  local _element _dir
  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    for _dir in "${_element}"/*/; do
      [[ -d "${_dir}" ]] && printf -- '%s\n' "${_dir%/}"
    done
  done | awk -F/ '{print $NF}' | sort -u
}

# @internal
# Print a library tree grouped by category, marking loaded libraries.
_shellac_ls_libraries() {
  local _element
  local _library_file
  local _rel_path
  local _category
  local _sentinel
  local _prev_category
  _prev_category=''

  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    while read -r _library_file; do
      # Skip redirect stubs — they are location aliases, not real libraries
      grep -qm1 '^# @redirect' "${_library_file}" 2>/dev/null && continue
      _rel_path="${_library_file#"${_element}/"}"
      _category="${_rel_path%/*}"
      # bashism: [[ ]] conditional; not POSIX sh
      [[ "${_category}" = "${_rel_path}" ]] && _category='.'
      if [[ "${_category}" != "${_prev_category}" ]]; then
        printf -- '\n%s/\n' "${_category}"
        _prev_category="${_category}"
      fi
      _sentinel="_SHELLAC_LOADED_${_rel_path%.sh}"
      # bashism: ${var//pattern/repl} pattern substitution; not POSIX sh
      _sentinel="${_sentinel//\//_}"
      # bashism: ${!var} indirect expansion; bash-specific
      if [[ -n "${!_sentinel+x}" ]]; then
        printf -- '  %-40s %s\n' "${_rel_path##*/}" "(loaded)"
      else
        printf -- '  %s\n' "${_rel_path##*/}"
      fi
    # bashism: < <() process substitution; not POSIX sh
    done < <(find "${_element}" -type f -name "*.sh" | sort)
  done
}

# @internal
# Print a flat list of all public functions with their @description summaries.
# Functions marked @internal are suppressed. Loaded functions are marked.
_shellac_ls_functions() {
  local _element
  local _library_file
  local _line
  local _pending_desc
  local _skip_next
  local _func_name
  local _func_status

  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    while read -r _library_file; do
      _pending_desc=''
      _skip_next=0
      while IFS= read -r _line; do
        # bashism: [[ ]] with glob/regex matching; not POSIX sh
        if [[ "${_line}" = '# @internal'* ]]; then
          _skip_next=1
          _pending_desc=''
        elif [[ "${_line}" = '# @description '* ]]; then
          _pending_desc="${_line#'# @description '}"
          _skip_next=0
        elif [[ "${_line}" = '# @description' ]]; then
          _pending_desc=''
          _skip_next=0
        # bashism: [[ =~ ]] regex match and BASH_REMATCH capture array; bash-specific
        elif [[ "${_line}" =~ ^[a-zA-Z][a-zA-Z0-9_]*\(\) ]]; then
          if (( ! _skip_next )); then
            _func_name="${BASH_REMATCH[0]%()}"
            if _is_function_loaded "${_func_name}"; then
              _func_status='(loaded)'
            else
              _func_status=''
            fi
            printf -- '  %-35s %-55s %s\n' \
              "${_func_name}" \
              "${_pending_desc:-(undocumented)}" \
              "${_func_status}"
          fi
          _pending_desc=''
          _skip_next=0
        fi
      done < "${_library_file}"
    # bashism: < <() process substitution; not POSIX sh
    done < <(find "${_element}" -type f -name "*.sh" | sort)
  done
}

# @internal
# Append a path to the shellac paths.conf config file.
# Idempotent: silently skips if the path is already present.
_shellac_add_libpath() {
  local new_path
  new_path="${1:?shellac add-libpath: no path provided}"

  if [ ! -d "${SHELLAC_CONFIG_DIR}" ]; then
    mkdir -p "${SHELLAC_CONFIG_DIR}" || {
      printf -- 'shellac: failed to create %s\n' "${SHELLAC_CONFIG_DIR}" >&2
      return 1
    }
  fi

  if [ -f "${SHELLAC_PATHS_CONF}" ] && grep -qxF "${new_path}" "${SHELLAC_PATHS_CONF}" 2>/dev/null; then
    printf -- 'shellac: %s is already in %s\n' "${new_path}" "${SHELLAC_PATHS_CONF}" >&2
    return 0
  fi

  printf -- '%s\n' "${new_path}" >> "${SHELLAC_PATHS_CONF}" || {
    printf -- 'shellac: failed to write to %s\n' "${SHELLAC_PATHS_CONF}" >&2
    return 1
  }
  printf -- 'shellac: added %s to %s\n' "${new_path}" "${SHELLAC_PATHS_CONF}"
}

# @internal
# Remove a path from the shellac paths.conf config file.
_shellac_rm_libpath() {
  local rm_path
  rm_path="${1:?shellac rm-libpath: no path provided}"

  if [ ! -f "${SHELLAC_PATHS_CONF}" ] || ! grep -qxF "${rm_path}" "${SHELLAC_PATHS_CONF}" 2>/dev/null; then
    printf -- 'shellac: %s not found in %s\n' "${rm_path}" "${SHELLAC_PATHS_CONF}" >&2
    return 1
  fi

  # Write to a tempfile then replace, to avoid clobbering on failure
  local tmp_file
  tmp_file="$(mktemp)" || {
    printf -- 'shellac: failed to create temp file\n' >&2
    return 1
  }
  trap 'rm -f "${tmp_file}"' EXIT

  # grep -v returns exit code 1 when no lines remain (e.g. removing the last entry),
  # so separate the grep and mv rather than chaining with &&.
  grep -vxF "${rm_path}" "${SHELLAC_PATHS_CONF}" > "${tmp_file}"
  if ! mv "${tmp_file}" "${SHELLAC_PATHS_CONF}"; then
    printf -- 'shellac: failed to update %s\n' "${SHELLAC_PATHS_CONF}" >&2
    return 1
  fi
  printf -- 'shellac: removed %s from %s\n' "${rm_path}" "${SHELLAC_PATHS_CONF}"
}

# @internal
# Append a path to the shellac confpaths.conf config file.
# Idempotent: silently skips if the path is already present.
_shellac_add_confpath() {
  local new_path
  new_path="${1:?shellac add-confpath: no path provided}"

  if [ ! -d "${SHELLAC_CONFIG_DIR}" ]; then
    mkdir -p "${SHELLAC_CONFIG_DIR}" || {
      printf -- 'shellac: failed to create %s\n' "${SHELLAC_CONFIG_DIR}" >&2
      return 1
    }
  fi

  if [ -f "${SHELLAC_CONFPATHS_CONF}" ] && grep -qxF "${new_path}" "${SHELLAC_CONFPATHS_CONF}" 2>/dev/null; then
    printf -- 'shellac: %s is already in %s\n' "${new_path}" "${SHELLAC_CONFPATHS_CONF}" >&2
    return 0
  fi

  printf -- '%s\n' "${new_path}" >> "${SHELLAC_CONFPATHS_CONF}" || {
    printf -- 'shellac: failed to write to %s\n' "${SHELLAC_CONFPATHS_CONF}" >&2
    return 1
  }
  printf -- 'shellac: added %s to %s\n' "${new_path}" "${SHELLAC_CONFPATHS_CONF}"
}

# @internal
# Remove a path from the shellac confpaths.conf config file.
_shellac_rm_confpath() {
  local rm_path
  rm_path="${1:?shellac rm-confpath: no path provided}"

  if [ ! -f "${SHELLAC_CONFPATHS_CONF}" ] || ! grep -qxF "${rm_path}" "${SHELLAC_CONFPATHS_CONF}" 2>/dev/null; then
    printf -- 'shellac: %s not found in %s\n' "${rm_path}" "${SHELLAC_CONFPATHS_CONF}" >&2
    return 1
  fi

  local tmp_file
  tmp_file="$(mktemp)" || {
    printf -- 'shellac: failed to create temp file\n' >&2
    return 1
  }
  trap 'rm -f "${tmp_file}"' EXIT

  # grep -v returns exit code 1 when no lines remain (e.g. removing the last entry),
  # so separate the grep and mv rather than chaining with &&.
  grep -vxF "${rm_path}" "${SHELLAC_CONFPATHS_CONF}" > "${tmp_file}"
  if ! mv "${tmp_file}" "${SHELLAC_CONFPATHS_CONF}"; then
    printf -- 'shellac: failed to update %s\n' "${SHELLAC_CONFPATHS_CONF}" >&2
    return 1
  fi
  printf -- 'shellac: removed %s from %s\n' "${rm_path}" "${SHELLAC_CONFPATHS_CONF}"
}

# @internal
# Install a library file from a local path or HTTPS URL into a target directory.
# When no target directory is given, defaults to ${HOME}/.local/lib/sh (non-root)
# or /usr/local/lib/sh (root).  For GitHub raw URLs the repo owner is used as a
# subdirectory namespace (e.g. contoso/pandas.sh), matching the shellac
# 'include owner/lib' convention.  The base target directory is registered in
# paths.conf if not already known to shellac.  Set SHELLAC_INSTALL_YES=1 to skip
# the confirmation prompt.
_shellac_add_lib() {
  local _source
  local _target_dir
  local _install_dir
  local _github_owner
  local _url_path
  local _filename
  local _dest
  local _tmp_file
  local _reply
  local _element
  local _already_known

  _source="${1:?shellac add-lib: source required}"
  _target_dir="${2:-}"

  # Scope resolution when no target directory is given
  if [[ -z "${_target_dir}" ]]; then
    if (( EUID == 0 )); then
      _target_dir="/usr/local/lib/sh"
    else
      _target_dir="${HOME}/.local/lib/sh"
    fi
  fi

  # Warning prompt — bypassed by SHELLAC_INSTALL_YES=1
  if [[ "${SHELLAC_INSTALL_YES:-0}" != "1" ]]; then
    printf -- 'Warning: shellac add-lib copies an unchecked library from an external source.\n' >&2
    printf -- 'No signature, checksum, or licence validation is performed.\n' >&2
    printf -- 'Proceed? [y/N] ' >&2
    IFS= read -r _reply
    case "${_reply}" in
      ([yY]|[yY][eE][sS]) ;;
      (*)
        printf -- 'shellac add-lib: aborted\n' >&2
        return 1
      ;;
    esac
  fi

  # Derive filename from source — strip leading path; strip query string for URLs
  _filename="${_source##*/}"
  _filename="${_filename%%\?*}"

  if [[ -z "${_filename}" ]]; then
    printf -- 'shellac add-lib: could not determine filename from: %s\n' "${_source}" >&2
    return 1
  fi

  # For GitHub raw URLs, namespace the install under the repo owner so the file
  # lands at target-dir/owner/file.sh and can be loaded as 'include owner/lib'.
  _install_dir="${_target_dir}"
  _github_owner=""
  case "${_source}" in
    (*raw.githubusercontent.com/*|*raw.github.com/*)
      _url_path="${_source#https://}"
      _url_path="${_url_path#*/}"
      _github_owner="${_url_path%%/*}"
      [[ -n "${_github_owner}" ]] && _install_dir="${_target_dir}/${_github_owner}"
    ;;
  esac

  _dest="${_install_dir}/${_filename}"

  # Ensure the install directory exists
  if [[ ! -d "${_install_dir}" ]]; then
    mkdir -p "${_install_dir}" || {
      printf -- 'shellac add-lib: failed to create directory %s\n' "${_install_dir}" >&2
      return 1
    }
  fi

  # Fetch (URL) or copy (local path)
  case "${_source}" in
    (https://*)
      _tmp_file="$(mktemp)" || {
        printf -- 'shellac add-lib: failed to create temp file\n' >&2
        return 1
      }
      trap 'rm -f "${_tmp_file}"' EXIT

      if command -v curl >/dev/null 2>&1; then
        if ! curl -fsSL "${_source}" > "${_tmp_file}"; then
          printf -- 'shellac add-lib: curl failed to fetch %s\n' "${_source}" >&2
          return 1
        fi
      elif command -v wget >/dev/null 2>&1; then
        if ! wget -qO- "${_source}" > "${_tmp_file}"; then
          printf -- 'shellac add-lib: wget failed to fetch %s\n' "${_source}" >&2
          return 1
        fi
      else
        printf -- 'shellac add-lib: neither curl nor wget found\n' >&2
        return 1
      fi

      if ! cp -- "${_tmp_file}" "${_dest}"; then
        printf -- 'shellac add-lib: failed to copy to %s\n' "${_dest}" >&2
        return 1
      fi
    ;;
    (*)
      if [[ ! -f "${_source}" ]]; then
        printf -- 'shellac add-lib: source not found: %s\n' "${_source}" >&2
        return 1
      fi
      if ! cp -- "${_source}" "${_dest}"; then
        printf -- 'shellac add-lib: failed to copy to %s\n' "${_dest}" >&2
        return 1
      fi
    ;;
  esac

  printf -- 'shellac add-lib: installed %s to %s\n' "${_filename}" "${_dest}"
  if [[ -n "${_github_owner}" ]]; then
    printf -- 'shellac add-lib: load with: include %s/%s\n' \
      "${_github_owner}" "${_filename%.sh}"
  fi

  # Register the base target directory in paths.conf if not already in SH_LIBPATH
  _already_known=0
  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    if [[ "${_element}" = "${_target_dir}" ]]; then
      _already_known=1
      break
    fi
  done

  if (( _already_known )); then
    printf -- 'shellac add-lib: %s is already in SH_LIBPATH — skipping registration\n' "${_target_dir}"
  else
    _shellac_add_libpath "${_target_dir}"
  fi
}

# @internal
# Remove an installed library file.  Does not modify paths.conf — use
# 'shellac rm-libpath' to deregister the containing directory if needed.
_shellac_rm_lib() {
  local _target
  _target="${1:?shellac rm-lib: file path required}"

  if [[ ! -f "${_target}" ]]; then
    printf -- 'shellac rm-lib: file not found: %s\n' "${_target}" >&2
    return 1
  fi

  if ! rm -- "${_target}"; then
    printf -- 'shellac rm-lib: failed to remove %s\n' "${_target}" >&2
    return 1
  fi

  printf -- 'shellac rm-lib: removed %s\n' "${_target}"
  printf -- 'shellac rm-lib: if %s is now empty, use "shellac rm-libpath %s" to deregister it\n' \
    "${_target%/*}" "${_target%/*}"
}

# @internal
# Print functions and one-line descriptions from a single library file.
_shellac_info_file() {
  local _file _element _rel_path _line _pending_desc _skip_next _func_name _func_status
  _file="${1}"
  _rel_path="${_file}"
  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    if [[ "${_file}" = "${_element}/"* ]]; then
      _rel_path="${_file#"${_element}/"}"
      break
    fi
  done
  printf -- '\n%s\n' "${_rel_path}"
  _pending_desc=''
  _skip_next=0
  while IFS= read -r _line; do
    if [[ "${_line}" = '# @internal'* ]]; then
      _skip_next=1
      _pending_desc=''
    elif [[ "${_line}" = '# @description '* ]]; then
      _pending_desc="${_line#'# @description '}"
      _skip_next=0
    elif [[ "${_line}" = '# @description' ]]; then
      _pending_desc=''
      _skip_next=0
    elif [[ "${_line}" =~ ^[a-zA-Z][a-zA-Z0-9_]*\(\) ]]; then
      if (( ! _skip_next )); then
        _func_name="${BASH_REMATCH[0]%()}"
        if _is_function_loaded "${_func_name}"; then
          _func_status='(loaded)'
        else
          _func_status=''
        fi
        printf -- '  %-35s %-50s %s\n' \
          "${_func_name}" "${_pending_desc:-(undocumented)}" "${_func_status}"
      fi
      _pending_desc=''
      _skip_next=0
    fi
  done < "${_file}"
}

# @internal
# Print functions and descriptions for all files in a module directory.
_shellac_info_module() {
  local _dir _file _module
  _dir="${1}"
  _module="${_dir##*/}"
  printf -- '%s/\n' "${_module}"
  while read -r _file; do
    grep -qm1 '^# @redirect' "${_file}" 2>/dev/null && continue
    _shellac_info_file "${_file}"
  done < <(find "${_dir}" -type f -name "*.sh" | sort)
}

# @internal
# Print the full shdoc block for a named function across all library files.
_shellac_info_function() {
  local _func _element _library_file _rel_path _line _state _desc _stdout _found
  local _arg _ex _ec
  local _args _examples _exitcodes
  _func="${1}"
  _found=0

  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    while read -r _library_file; do
      _state='none'
      _desc=''
      _args=()
      _examples=()
      _stdout=''
      _exitcodes=()
      while IFS= read -r _line; do
        case "${_line}" in
          ('# @internal'*)
            _state='skip'
            _desc=''; _args=(); _examples=(); _stdout=''; _exitcodes=()
          ;;
          ('# @description '*)
            _state='description'
            _desc="${_line#'# @description '}"
            _args=(); _examples=(); _stdout=''; _exitcodes=()
          ;;
          ('# @description')
            _state='description'
            _desc=''
            _args=(); _examples=(); _stdout=''; _exitcodes=()
          ;;
          ('# @arg '*)
            _args+=( "${_line#'# @arg '}" )
          ;;
          ('# @example')
            _state='example'
          ;;
          ('# @stdout '*)
            _stdout="${_line#'# @stdout '}"
          ;;
          ('# @exitcode '*)
            _exitcodes+=( "${_line#'# @exitcode '}" )
          ;;
          ('#   '*)
            case "${_state}" in
              (description) _desc="${_desc} ${_line#'#   '}" ;;
              (example)     _examples+=( "${_line#'#   '}" ) ;;
            esac
          ;;
          (*)
            if [[ "${_line}" =~ ^${_func}\(\) ]] && [[ "${_state}" != 'skip' ]]; then
              _found=1
              _rel_path="${_library_file#"${_element}/"}"
              printf -- '%s\n' "${_func}"
              if _is_function_loaded "${_func}"; then
                printf -- '  %s (loaded)\n' "${_rel_path}"
              else
                printf -- '  %s\n' "${_rel_path}"
              fi
              [[ -n "${_desc}" ]] && printf -- '\n  %s\n' "${_desc}"
              if (( ${#_args[@]} > 0 )); then
                printf -- '\n  Arguments:\n'
                for _arg in "${_args[@]}"; do
                  printf -- '    %s\n' "${_arg}"
                done
              fi
              if (( ${#_examples[@]} > 0 )); then
                printf -- '\n  Examples:\n'
                for _ex in "${_examples[@]}"; do
                  printf -- '    %s\n' "${_ex}"
                done
              fi
              [[ -n "${_stdout}" ]] && printf -- '\n  Stdout:\n    %s\n' "${_stdout}"
              if (( ${#_exitcodes[@]} > 0 )); then
                printf -- '\n  Exit codes:\n'
                for _ec in "${_exitcodes[@]}"; do
                  printf -- '    %s\n' "${_ec}"
                done
              fi
              break 3
            fi
            _state='none'
            _desc=''; _args=(); _examples=(); _stdout=''; _exitcodes=()
          ;;
        esac
      done < "${_library_file}"
    done < <(find "${_element}" -type f -name "*.sh" | sort)
  done

  if (( ! _found )); then
    printf -- 'shellac info: %s: not found\n' "${_func}" >&2
    return 1
  fi
}

# @internal
# Dispatcher for 'shellac info': resolves target as module, file, or function.
_shellac_info() {
  local _target _element _found
  _target="${1:-}"
  _found=0

  if [[ -z "${_target}" ]]; then
    printf -- 'shellac info: missing argument\n' >&2
    return 1
  fi

  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    if [[ -d "${_element}/${_target}" ]]; then
      _shellac_info_module "${_element}/${_target}"
      _found=1
      break
    fi
    if [[ -f "${_element}/${_target}" ]]; then
      _shellac_info_file "${_element}/${_target}"
      _found=1
      break
    fi
    if [[ -f "${_element}/${_target}.sh" ]]; then
      _shellac_info_file "${_element}/${_target}.sh"
      _found=1
      break
    fi
  done

  (( _found )) || _shellac_info_function "${_target}"
}

# @internal
# Reverse lookup: which library file(s) define a given function.
_shellac_provides() {
  local _func _element _library_file _rel_path _found
  _func="${1:-}"
  _found=0

  if [[ -z "${_func}" ]]; then
    printf -- 'shellac provides: missing argument\n' >&2
    return 1
  fi

  for _element in "${SH_LIBPATH_ARRAY[@]}"; do
    while read -r _library_file; do
      if grep -qm1 "^${_func}()" "${_library_file}" 2>/dev/null; then
        _rel_path="${_library_file#"${_element}/"}"
        if (( ! _found )); then
          printf -- '%s is provided by:\n' "${_func}"
          _found=1
        fi
        if _is_function_loaded "${_func}"; then
          printf -- '  %s (loaded)\n' "${_rel_path}"
        else
          printf -- '  %s\n' "${_rel_path}"
        fi
      fi
    done < <(find "${_element}" -type f -name "*.sh" | sort)
  done

  if (( ! _found )); then
    printf -- 'shellac provides: %s: not found\n' "${_func}" >&2
    return 1
  fi
}

# @internal
# Configure PATH and SH_LIBPATH for the current shellac clone.
# Writes /etc/profile.d/00-shellac.sh (if writable) or appends to ~/.bashrc.
# Idempotent: skips any line already present. Reports every change made.
_shellac_init() {
  local clone_root bin_path lib_path target_file install_type
  local path_line libpath_line reload_cmd changed
  changed=0

  # Derive clone root from the location of bin/shellac itself
  clone_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
  clone_root="${clone_root%/bin}"
  bin_path="${clone_root}/bin"
  lib_path="${clone_root}/lib/sh"

  printf -- 'shellac init: detected clone at %s\n' "${clone_root}"

  if [ ! -d "${lib_path}" ]; then
    printf -- 'shellac init: lib/sh not found at %s — is this a complete clone?\n' "${lib_path}" >&2
    return 1
  fi

  # Choose system vs per-user install based on write access to /etc/profile.d/
  if [ -d /etc/profile.d ] && [ -w /etc/profile.d ]; then
    install_type=system
    target_file=/etc/profile.d/00-shellac.sh
    printf -- 'shellac init: /etc/profile.d/ is writable — system-wide install\n'
    reload_cmd="source ${target_file}"
  else
    install_type=user
    if [ -f "${HOME}/.bashrc" ]; then
      target_file="${HOME}/.bashrc"
    else
      target_file="${HOME}/.profile"
    fi
    printf -- 'shellac init: /etc/profile.d/ is not writable — per-user install\n'
    reload_cmd="source ${target_file}"
  fi

  path_line="export PATH=\"${bin_path}:\${PATH}\""
  libpath_line="export SH_LIBPATH=\"${lib_path}\""

  if [ "${install_type}" = system ]; then
    if [ ! -f "${target_file}" ]; then
      printf -- '# Shellac shell library — https://github.com/rawiriblundell/shellac\n' \
        > "${target_file}" || {
        printf -- 'shellac init: failed to write %s\n' "${target_file}" >&2
        return 1
      }
      printf -- 'shellac init: created %s\n' "${target_file}"
      changed=$(( changed + 1 ))
    else
      printf -- 'shellac init: %s already exists\n' "${target_file}"
    fi

    if ! grep -qF "${bin_path}" "${target_file}" 2>/dev/null; then
      printf -- '%s\n' "${path_line}" >> "${target_file}"
      printf -- 'shellac init: added PATH entry to %s\n' "${target_file}"
      changed=$(( changed + 1 ))
    else
      printf -- 'shellac init: PATH entry already present in %s\n' "${target_file}"
    fi

    if ! grep -qF "${lib_path}" "${target_file}" 2>/dev/null; then
      printf -- '%s\n' "${libpath_line}" >> "${target_file}"
      printf -- 'shellac init: added SH_LIBPATH to %s\n' "${target_file}"
      changed=$(( changed + 1 ))
    else
      printf -- 'shellac init: SH_LIBPATH already present in %s\n' "${target_file}"
    fi
  else
    printf -- 'shellac init: target file: %s\n' "${target_file}"

    if ! grep -qF "${bin_path}" "${target_file}" 2>/dev/null; then
      printf -- '\n# Shellac shell library — https://github.com/rawiriblundell/shellac\n%s\n' \
        "${path_line}" >> "${target_file}"
      printf -- 'shellac init: added PATH entry to %s\n' "${target_file}"
      changed=$(( changed + 1 ))
    else
      printf -- 'shellac init: PATH entry already present in %s\n' "${target_file}"
    fi

    if ! grep -qF "${lib_path}" "${target_file}" 2>/dev/null; then
      printf -- '%s\n' "${libpath_line}" >> "${target_file}"
      printf -- 'shellac init: added SH_LIBPATH to %s\n' "${target_file}"
      changed=$(( changed + 1 ))
    else
      printf -- 'shellac init: SH_LIBPATH already present in %s\n' "${target_file}"
    fi
  fi

  if (( changed > 0 )); then
    printf -- 'shellac init: %d change(s) made — reload with: %s\n' "${changed}" "${reload_cmd}"
  else
    printf -- 'shellac init: nothing to do — already configured\n'
  fi
}

# @description shellac subcommand dispatcher.
#   Provides a unified interface to shellac's core functions.
#
# @arg $1 string Subcommand: init, add-lib, rm-lib, include, requires, wants, libraries, functions, info, provides
#
# @example
#   shellac include text/trim
#   shellac requires curl git
#   shellac wants /etc/myapp/overrides.conf
#   shellac libraries
#   shellac functions
#   shellac info time
#   shellac info time/dst.sh
#   shellac info dst_is_active
#   shellac provides dst_is_active
#
# @exitcode 0 Subcommand succeeded
# @exitcode 1 Unknown subcommand or subcommand failed
shellac() {
  local _subcmd
  _subcmd="${1:-}"
  shift 2>/dev/null

  case "${_subcmd}" in
    (include)      include "${@}" ;;
    (requires)     requires "${@}" ;;
    (wants)        wants "${@}" ;;
    (modules)      _shellac_ls_modules ;;
    (libraries)    _shellac_ls_libraries ;;
    (functions)    _shellac_ls_functions | sort ;;
    (info)         _shellac_info "${@}" ;;
    (provides)     _shellac_provides "${@}" ;;
    (init)          _shellac_init ;;
    (add-lib)       _shellac_add_lib "${@}" ;;
    (rm-lib)        _shellac_rm_lib "${@}" ;;
    (add-libpath)   _shellac_add_libpath "${@}" ;;
    (rm-libpath)    _shellac_rm_libpath "${@}" ;;
    (add-confpath)  _shellac_add_confpath "${@}" ;;
    (rm-confpath)   _shellac_rm_confpath "${@}" ;;
    (stack)         _shellac_stack "${@}" ;;
    ('')
      printf -- '%s\n' \
        "Usage: shellac <subcommand> [args]" \
        "" \
        "Subcommands:" \
        "  init                 Configure PATH and SH_LIBPATH for this install" \
        "  add-lib <src> [dir]  Install a library from a local path or URL" \
        "  rm-lib <file>        Remove an installed library file" \
        "  include <lib>        Load a library from SH_LIBPATH" \
        "  requires <deps>      Assert that commands, files or shell version are present" \
        "  wants <file>         Source a file if it exists; silently skip if not" \
        "  modules              List available modules" \
        "  libraries            List available libraries" \
        "  functions            List available functions" \
        "  info <target>        Show functions for a module, file, or full help for a function" \
        "  provides <func>      Show which library file(s) define a function" \
        "  add-libpath <path>    Append a path to ${SHELLAC_PATHS_CONF}" \
        "  rm-libpath <path>     Remove a path from ${SHELLAC_PATHS_CONF}" \
        "  add-confpath <path>   Append a path to ${SHELLAC_CONFPATHS_CONF}" \
        "  rm-confpath <path>    Remove a path from ${SHELLAC_CONFPATHS_CONF}" \
        "  stack dump            Print the trace stack" \
        "  stack clear           Clear the trace stack" >&2
      return 1
    ;;
    (*)
      printf -- 'shellac: unknown subcommand: %s\n' "${_subcmd}" >&2
      return 1
    ;;
  esac
}

# Make color and text-effect variables available immediately in interactive shells.
# $- contains 'i' when the shell is interactive; non-interactive scripts are unaffected.
[[ $- = *i* ]] && include "text/color"
